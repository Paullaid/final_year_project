rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Development-only profile: open reads/writes while building.
    match /{document=**} {
      allow read, write: if false;
    }

    // Public app browsing data (read for signed-in users; writes via admin panel).
    match /questions/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /pastQuestions/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /courses/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /departments/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /faculties/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }
    function isAdmin() {
      return request.auth != null
        && (
          request.auth.token.role == 'admin'
          || request.auth.token.admin == true
          || request.auth.token.isAdmin == true
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
        );
    }
  }
}
